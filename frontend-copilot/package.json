{
  "name": "frontend-copilot",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:hosted": "vite -- --runtime-model=test",
    "generate:icons": "node ./scripts/generate-icons.mjs",
    "prebuild": "npm run generate:icons",
    "build": "npm run build:app",
    "build:app": "tsc && vite build",
    "stage:bundled-runtime": "node ./scripts/prepare-bundled-runtime.mjs",
    "package:desktop": "electron-builder",
    "prepackage:desktop": "npm run build && npm run stage:bundled-runtime",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "node ./scripts/run-vitest.mjs"
  },
  "dependencies": {
    "@copilotkit/react-core": "^1.53.0",
    "@copilotkit/react-ui": "^0.2.0",
    "@copilotkit/shared": "^1.53.0",
    "lucide-react": "^0.577.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "png2icons": "^2.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.2.2",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.0"
  },
  "main": "dist-electron/main.js"
}
