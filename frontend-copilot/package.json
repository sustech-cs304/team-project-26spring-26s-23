{
  "name": "candue",
  "private": true,
  "version": "0.0.0",
  "productName": "CanDue",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:icons": "node ./scripts/generate-icons.mjs",
    "postinstall": "electron-builder install-app-deps",
    "prebuild": "npm run generate:icons && cd ../backend && uv sync && cd ../frontend-copilot",
    "typecheck": "npm run typecheck:check",
    "typecheck:check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "build": "npm run typecheck && npm run build:app",
    "build:app": "vite build",
    "stage:bundled-runtime": "node ./scripts/prepare-bundled-runtime.mjs",
    "package:desktop": "electron-builder",
    "package:desktop:smoke": "npm run package:desktop -- --dir --publish never",
    "prepackage:desktop": "npm run build && npm run stage:bundled-runtime",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "lint:strict": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "node ./scripts/run-vitest.mjs"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "better-sqlite3": "^12.10.0",
    "frappe-gantt": "^1.2.2",
    "gsap": "^3.15.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.577.0",
    "mathjax-full": "^3.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react18-json-view": "^0.2.10",
    "rehype-highlight": "^7.0.2",
    "rehype-mathjax": "^7.1.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "eslint-plugin-sonarjs": "^4.0.3",
    "jsdom": "^29.0.1",
    "png2icons": "^2.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.2.2",
    "vite": "^7.3.2",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.4"
  },
  "main": "dist-electron/main.js"
}
