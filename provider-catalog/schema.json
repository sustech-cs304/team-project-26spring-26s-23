{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://candue.local/provider-catalog/schema.json",
  "title": "CanDue Provider Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["catalogRevision", "providers"],
  "properties": {
    "catalogRevision": {
      "type": "string",
      "minLength": 1
    },
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/providerCatalogEntry"
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "minLength": 1
    },
    "providerRuntimeStatus": {
      "type": "string",
      "enum": ["enabled", "catalog-only", "legacy-unsupported"]
    },
    "authKind": {
      "type": "string",
      "enum": ["api-key", "none"]
    },
    "authSchema": {
      "type": "object",
      "additionalProperties": false,
      "required": ["defaultKind", "supportedKinds", "secretFields"],
      "properties": {
        "defaultKind": {
          "$ref": "#/$defs/authKind"
        },
        "supportedKinds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/authKind"
          }
        },
        "secretFields": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-zA-Z][a-zA-Z0-9]*$"
          }
        },
        "helpText": {
          "type": "string"
        }
      }
    },
    "baseUrlPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["fixed", "optional", "required"]
        },
        "defaultBaseUrl": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "modelConfigPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "allowCustomModels", "defaultModelRequired"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["user-defined", "catalog-seeded", "read-only"]
        },
        "allowCustomModels": {
          "type": "boolean"
        },
        "defaultModelRequired": {
          "type": "boolean"
        },
        "allowModelDisplayNameOverride": {
          "type": "boolean"
        }
      }
    },
    "capabilityHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "streaming": {
          "type": "boolean"
        },
        "tools": {
          "type": "boolean"
        },
        "vision": {
          "type": "boolean"
        },
        "reasoning": {
          "type": "boolean"
        },
        "search": {
          "type": "boolean"
        }
      }
    },
    "providerCatalogEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "providerId",
        "displayName",
        "endpointType",
        "runtimeStatus",
        "adapterId",
        "authSchema",
        "baseUrlPolicy",
        "modelConfigPolicy",
        "capabilityHints"
      ],
      "properties": {
        "providerId": {
          "$ref": "#/$defs/identifier"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "endpointType": {
          "$ref": "#/$defs/identifier"
        },
        "runtimeStatus": {
          "$ref": "#/$defs/providerRuntimeStatus"
        },
        "adapterId": {
          "$ref": "#/$defs/identifier"
        },
        "authSchema": {
          "$ref": "#/$defs/authSchema"
        },
        "baseUrlPolicy": {
          "$ref": "#/$defs/baseUrlPolicy"
        },
        "modelConfigPolicy": {
          "$ref": "#/$defs/modelConfigPolicy"
        },
        "capabilityHints": {
          "$ref": "#/$defs/capabilityHints"
        },
        "aliases": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
