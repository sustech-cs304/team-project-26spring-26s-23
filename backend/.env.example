# CanDue Desktop Runtime 配置变量
# 当前 runtime 使用 COPILOT_DESKTOP_RUNTIME_* 命名空间
# 变量来源：backend/app/desktop_runtime/config.py

# === 网络与模式 ===
COPILOT_DESKTOP_RUNTIME_HOST=127.0.0.1
COPILOT_DESKTOP_RUNTIME_PORT=8765
COPILOT_DESKTOP_RUNTIME_APP_MODE=desktop
COPILOT_DESKTOP_RUNTIME_ENVIRONMENT=development

# === 认证 ===
COPILOT_DESKTOP_RUNTIME_LOCAL_TOKEN=

# === 目录 ===
COPILOT_DESKTOP_RUNTIME_USER_DATA_DIR=
COPILOT_DESKTOP_RUNTIME_ROOT_DIR=
COPILOT_DESKTOP_RUNTIME_CONFIG_DIR=
COPILOT_DESKTOP_RUNTIME_LOGS_DIR=
COPILOT_DESKTOP_RUNTIME_DATABASE_DIR=
COPILOT_DESKTOP_RUNTIME_STATE_DIR=

# === 文件路径 ===
COPILOT_DESKTOP_RUNTIME_SETTINGS_FILE=
COPILOT_DESKTOP_RUNTIME_HOST_LOG_FILE=
COPILOT_DESKTOP_RUNTIME_BACKEND_STDOUT_LOG_FILE=
COPILOT_DESKTOP_RUNTIME_BACKEND_STDERR_LOG_FILE=
COPILOT_DESKTOP_RUNTIME_SNAPSHOT_FILE=
COPILOT_DESKTOP_RUNTIME_LAST_FAILURE_FILE=
COPILOT_DESKTOP_RUNTIME_DEBUG_LOG_DATABASE_FILE=

# === 调试日志 ===
COPILOT_DESKTOP_RUNTIME_DEBUG_LOG_RETENTION_DAYS=14
COPILOT_DESKTOP_RUNTIME_DEBUG_LOG_AUTO_CLEANUP_ENABLED=true
COPILOT_DESKTOP_RUNTIME_DEBUG_LOG_MIN_CLEANUP_INTERVAL_SECONDS=21600
COPILOT_DESKTOP_RUNTIME_DEBUG_LOG_SNAPSHOT_RETENTION_DAYS=

# === 宿主私桥 ===
COPILOT_DESKTOP_RUNTIME_HOST_CAPABILITY_BRIDGE_URL=
COPILOT_DESKTOP_RUNTIME_HOST_CAPABILITY_BRIDGE_TOKEN=

# === 后端版本标识 ===
COPILOT_DESKTOP_RUNTIME_BACKEND_VERSION=
